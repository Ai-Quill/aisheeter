# ============================================================
# AISheeter Backend — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# --- Database (Neon PostgreSQL) ---
# Sign up at https://neon.tech and create a database
NEON_DB_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Encryption ---
# Used to encrypt/decrypt user API keys at rest
# Generate with: node -e "console.log(require('crypto').randomUUID())"
ENCRYPTION_SALT="generate-a-uuid-here"

# --- App URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AWS S3 (for image generation storage) ---
# Optional: only needed if using image generation feature
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME=""

# --- Stripe (for payments) ---
# Optional: only needed if enabling paid tiers
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PRO=""

# --- Managed AI Keys (optional) ---
# If you want to provide AI access without users needing their own keys
# Leave empty to require users to bring their own keys (BYOK)
MANAGED_OPENAI_API_KEY=""
MANAGED_ANTHROPIC_API_KEY=""
MANAGED_GOOGLE_API_KEY=""
MANAGED_GROQ_API_KEY=""

# --- Upstash Redis (for rate limiting) ---
# Optional: rate limiting works without Redis but with less precision
# Sign up at https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Sentry (error tracking) ---
# Optional: for production error monitoring
SENTRY_DSN=""

# --- Cron Secret ---
# Used to authenticate cron job requests
CRON_SECRET=""
